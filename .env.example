# ===== Server Configuration =====
PORT=5000
NODE_ENV=development

# ===== Authentication =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===== Database =====
# MongoDB Connection String
# Local: mongodb://localhost:27017/phonix
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/phonix?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/phonix

# ===== Frontend Configuration =====
FRONTEND_URL=http://localhost:5173

# ===== Google OAuth (Optional) =====
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ===== AWS S3 Configuration (Optional) =====
# For production file uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=phonix-bots

# ===== Email Configuration (Optional) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-email-password
# EMAIL_FROM=noreply@phonix.com

# ===== Market Data APIs (REQUIRED FOR MARKETS FEATURE) =====
# Alpha Vantage - Comprehensive real-time stock market data
# Sign up: https://www.alphavantage.co/
# Paid tier: 500 calls/day, includes all premium APIs
# APIs supported: Stock quotes, technical indicators, fundamentals, news sentiment, earnings, forex, crypto, commodities
ALPHA_VANTAGE_KEY=your_official_api_key_here

# ===== AI & LLM Configuration (REQUIRED FOR MARKET ANALYSIS) =====
# OpenRouter API - For intelligent market analysis with multiple model options
# Sign up: https://openrouter.ai/
# Free tier available with reasoning-enabled models
# Currently using: stepfun/step-3.5-flash:free (free, reasoning-enabled alternative)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
